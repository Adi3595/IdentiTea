# ==================================================
# IDENTITEA ENVIRONMENT VARIABLES
# ==================================================
# Determine Environment: development, production, test
ENVIRONMENT=development

# --------------------------------------------------
# 1. Clerk Authentication
# --------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --------------------------------------------------
# 2. Supabase (PostgreSQL & Storage)
# --------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Local Docker DB Fallback
POSTGRES_USER=identitea
POSTGRES_PASSWORD=identitea
POSTGRES_DB=identitea
DATABASE_URL=postgresql://identitea:identitea@localhost:5432/identitea

# --------------------------------------------------
# 3. Neo4j AuraDB (Knowledge Graph)
# --------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# --------------------------------------------------
# 4. Qdrant Cloud (Vector Database)
# --------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --------------------------------------------------
# 5. Gemini API (LLM Orchestration)
# --------------------------------------------------
GEMINI_API_KEY=

# --------------------------------------------------
# 6. Backend API Configuration
# --------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
BACKEND_SECRET_KEY=generate_a_secret_key_here
