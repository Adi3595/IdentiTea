# ==================================================
# IDENTITEA ENVIRONMENT VARIABLES
# ==================================================
# Determine Environment: development, production, test
ENVIRONMENT=development

# --------------------------------------------------
# 1. Firebase Authentication (Frontend & Backend)
# --------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
FIREBASE_SERVICE_ACCOUNT_JSON=path/to/serviceAccountKey.json

# --------------------------------------------------
# 2. Supabase (PostgreSQL & Storage)
# --------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --------------------------------------------------
# 3. Neo4j AuraDB (Knowledge Graph)
# --------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# --------------------------------------------------
# 4. Gemini API (LLM Extraction Engine)
# --------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key

# --------------------------------------------------
# 5. API Security & Backend Configuration
# --------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api
API_KEY=your_secure_api_key_for_backend_calls
CORS_ORIGINS=http://localhost:3000,https://identitea.app
